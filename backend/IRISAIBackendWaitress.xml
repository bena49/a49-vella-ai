<service>
  <id>IRISAIBackendWaitress</id>
  <name>IRIS AI Backend (Vella)</name>
  <description>Django AI Backend for A49 Vella Revit Assistant using Waitress</description>

  <!-- Python executable inside your venv -->
  <executable>venv\Scripts\python.exe</executable>

  <!-- Waitress command -->
  <arguments>-m waitress --listen=127.0.0.1:8001 ai_backend.wsgi:application</arguments>

  <!-- Working directory for Django project -->
  <workingdirectory>D:\xampp\webapps\irisaiassistant_backend</workingdirectory>

  <!-- Logs -->
  <logpath>D:\xampp\webapps\irisaiassistant_backend\logs</logpath>
  <log mode="roll"></log>

  <!-- Auto-restart if it crashes -->
  <onfailure action="restart" />
</service>
